# maschinenraum configuration — copy to .env and edit. setup.sh fills the blanks.
# .env is gitignored; never commit real secrets.

# ── API ────────────────────────────────────────────────────────────────────
# Bearer token clients use. Leave blank and setup.sh generates a strong one.
MR_API_KEY=

# ── Model ──────────────────────────────────────────────────────────────────
# Leave blank to auto-pick from detected VRAM (see lib/pick_model.sh).
MR_MODEL=
# Fraction of VRAM for the main model. Auto-lowered when Whisper is enabled.
MR_GPU_MEMORY_UTILIZATION=0.90
# Extra raw flags passed verbatim to vLLM, space-separated.
# e.g. --max-model-len 8192 --max-num-seqs 64 --quantization awq
MR_EXTRA_ARGS=
# Pin a specific vLLM image for reproducibility (default: latest).
MR_VLLM_IMAGE=vllm/vllm-openai:latest
# Optional HuggingFace token, for gated models.
HF_TOKEN=

# ── Serving ────────────────────────────────────────────────────────────────
MR_PORT=8000

# ── Whisper / speech-to-text (dedicated faster-whisper server) ─────────────
# true = run a faster-whisper server for /v1/audio/* behind the router.
MR_ENABLE_WHISPER=true
# faster-whisper (CTranslate2) model id used in /v1/audio/transcriptions calls.
MR_WHISPER_MODEL=Systran/faster-whisper-large-v3
# cuda = share the GPU (small, predictable; core VRAM fraction auto-lowered).
# cpu  = zero GPU contention, slower on long audio.
MR_WHISPER_DEVICE=cuda
# default | int8 | float16 | int8_float16
MR_WHISPER_COMPUTE_TYPE=int8_float16
# Optional image override (defaults to the speaches cuda/cpu image by device).
MR_WHISPER_IMAGE=

# Port the Caddy router listens on (and what Cloudflare points at) when Whisper
# is enabled. With Whisper off, Cloudflare points straight at MR_PORT.
MR_EDGE_PORT=8080

# ── Cloudflare ─────────────────────────────────────────────────────────────
# Token from a named tunnel (dashboard) for a STABLE hostname. Leave blank to
# use a free ephemeral *.trycloudflare.com URL instead.
CLOUDFLARE_TUNNEL_TOKEN=
# Your public hostname, for documentation/printing only (e.g. ai.example.com).
MR_PUBLIC_HOSTNAME=

# ── Discord ────────────────────────────────────────────────────────────────
# Webhook for online/offline pings, daily health, weekly digest. Blank disables.
DISCORD_WEBHOOK_URL=
